Cell[CellGroupData[{

Cell["5. Hierarchical Style Clustering", "Section",ExpressionUUID->"289061ec-88ce-4ac3-8e57-2166eee0f7df"],

Cell["\<\
Hierarchical clustering groups creators into a tree structure based on cosine \
distance between their centroid embeddings. The dendrogram visualises this \
hierarchy: artists joined at lower levels (shorter branches) are more \
similar, while those joined only at the top are most different. The branching \
pattern reveals stylistic families \[LongDash] clusters of artists whose work \
shares a common semantic signature. These groupings sometimes mirror \
art-historical relationships (same school, period, or medium), but can also \
surface less obvious connections that the embedding model detects from the \
visual and textual content of the artworks themselves.\
\>", "Text",ExpressionUUID->"c2c83d72-32f5-477f-b2a1-39c77271de10"],

Cell[CellGroupData[{

Cell["\<\
(* Dendrogram of top creators by cosine distance *)
dendroN = Min[40, nCreators];
dendroNames = topCreatorNames[[1 ;; dendroN]];
dendroCentroids = centroidMatrix[[1 ;; dendroN]];

Dendrogram[
  MapThread[Rule, {dendroNames, dendroCentroids}],
  DistanceFunction -> CosineDistance,
  Bottom,
  DendrogramLayout -> \"Horizontal\",
  PlotLabel -> \"Creator Style Dendrogram (cosine distance)\",
  ImageSize -> {500, Max[400, dendroN * 18]}]\
\>", "Input",
 CellLabel->
  "In[255]:=",ExpressionUUID->"fdb47cdb-8926-43c2-a960-86b4b38aae90"],

Cell[BoxData[
 TemplateBox[{
  "Dendrogram", "nonopt", 
   "\"Options expected (instead of \\!\\(\\*RowBox[{\\\"Bottom\\\"}]\\)) \
beyond position \\!\\(\\*RowBox[{\\\"2\\\"}]\\) in \
\\!\\(\\*RowBox[{\\\"Dendrogram\\\", \\\"[\\\", RowBox[{\\\"\[LeftSkeleton]\\\
\", \\\"1\\\", \\\"\[RightSkeleton]\\\"}], \\\"]\\\"}]\\). An option must be \
a rule or a list of rules.\"", 2, 260, 1, 19714034685165324636, "Local"},
  "MessageTemplate",
  BaseStyle->"MSG"]], "Message",
 CellChangeTimes->{3.981557150200903*^9},
 CellLabel->
  "During evaluation of \
In[255]:=",ExpressionUUID->"c7823e88-79d0-425a-a727-2ab9f5e1bea8"],

Cell[BoxData[
 TemplateBox[<|"shortenedBoxes" -> TagBox[
     RowBox[{"Dendrogram", "[", 
       TemplateBox[{"1"}, "OutputSizeLimit`Skeleton"], "]"}], Short[#, 8]& ], 
   "line" -> 260, "sessionID" -> 19714034685165324636, "byteCount" -> 137128, 
   "size" -> 8, "stored" -> False, "expr" -> Missing["NotStored"], "wrap" -> 
   OutputSizeLimit`Defer, "version" -> 1|>,
  "OutputSizeLimitTemplate"]], "Output",
 CellChangeTimes->{3.981557150228067*^9},
 CellLabel->
  "Out[260]=",ExpressionUUID->"64a45699-b0ee-4302-9a89-434bb54a4892"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. Intra-Artist Style Diversity", "Section",ExpressionUUID->"01d9a96a-1848-4f37-b5b4-d8acd04e8cbb"],

Cell["\<\
Not all artists produce homogeneous work. Some stick to a signature style \
(their works form a tight cluster near the centroid), while others experiment \
across genres, media, or subjects (their works scatter widely in embedding \
space). We quantify this using the mean cosine distance from each artist\
\[CloseCurlyQuote]s individual works to their centroid \[LongDash] a larger \
value means greater stylistic diversity. Plotting diversity against \
productivity (number of works) reveals whether prolific artists tend to \
diversify over a long career or instead specialise further. The tables of \
most diverse and most consistent creators make the abstract metric concrete \
with specific names.\
\>", "Text",ExpressionUUID->"fc539110-7dbe-4f34-971f-c3a361cb87fb"],

Cell[CellGroupData[{

Cell["\<\
creatorDiversity = Association[Table[
  Module[{mask, creatorEmbs, centroid, dists},
    mask = Flatten[Position[creatorOf, name]];
    creatorEmbs = embeddings[[mask]];
    centroid = creatorCentroids[name];
    dists = 1 - creatorEmbs.centroid;
    name -> <|
      \"meanDist\" -> Mean[dists],
      \"stdDist\" -> If[Length[dists] > 1, StandardDeviation[dists], 0],
      \"nWorks\" -> Length[mask]|>],
  {name, topCreatorNames}]];

(* Diversity vs productivity *)
ListPlot[
  Table[
    Tooltip[
      {creatorDiversity[name][\"nWorks\"], \
creatorDiversity[name][\"meanDist\"]},
      name],
    {name, topCreatorNames}],
  PlotLabel -> \"Style Diversity vs. Number of Works\",
  AxesLabel -> {\"Works in Collection\", \"Mean Cosine Distance to Centroid\"},
  PlotStyle -> Directive[PointSize[0.01], Blue],
  PlotTheme -> \"Scientific\",
  ImageSize -> Large]\
\>", "Input",
 CellLabel->
  "In[261]:=",ExpressionUUID->"1ed2d9cd-7a36-4703-a10f-ca421051b41e"],

