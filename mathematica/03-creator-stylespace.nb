Cell[CellGroupData[{

Cell["\<\
Print[Style[\"\\nMost Dissimilar Creator Pairs:\", Bold]];
Grid[
  Prepend[
    Table[{pairs[[-i, 2]], pairs[[-i, 3]], NumberForm[pairs[[-i, 1]], 4]},
      {i, 10}],
    Style[#, Bold] & /@ {\"Creator 1\", \"Creator 2\", \"Cosine Similarity\"}],
  Frame -> All, Alignment -> {{Left, Left, Center}}]\
\>", "Input",
