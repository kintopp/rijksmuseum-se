Cell[CellGroupData[{

Cell["\<\
(* Scree plot *)
ListPlot[eigenvalues,
  PlotLabel -> \"PCA Scree Plot (384 dimensions)\",
  AxesLabel -> {\"Principal Component\", \"Eigenvalue\"},
  Filling -> Axis,
  FillingStyle -> Directive[Opacity[0.3], Blue],
  PlotTheme -> \"Scientific\",
  PlotRange -> All,
  ImageSize -> Large]\
