 TemplateBox[{
  "MatrixPlot", "cfun", 
   "\"The value of the option ColorFunction -> \
\\!\\(\\*RowBox[{\\\"\\\\\\\"Viridis\\\\\\\"\\\"}]\\) is not a valid color \
function or a gradient ColorData entity.\"", 2, 405, 6, 19714034685165324636, 
